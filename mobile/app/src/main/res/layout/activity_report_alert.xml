<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/gray_50"
    tools:context=".ReportAlertActivity">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/navy_blue"
        android:elevation="4dp"
        app:elevation="4dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/navy_blue"
            app:navigationIcon="@drawable/ic_arrow_back"
            app:navigationIconTint="@color/white">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Logo and Title Section -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <!-- Logo -->
                    <FrameLayout
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@drawable/logo_background">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_alert_triangle"
                            android:background="@drawable/logo_background" />

                    </FrameLayout>

                    <!-- Title and Subtitle -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginStart="8dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Report Alert"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-medium" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="..."
                            android:textSize="12sp"
                            android:textColor="@color/gray_300" />

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.appbar.MaterialToolbar>

    </com.google.android.material.appbar.AppBarLayout>

    <!-- Main Content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:paddingBottom="80dp">

            <!-- Weather Alert Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/weatherAlertCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/status_blue"/>

            <!-- Alert Category Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Category"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/navy_blue"
                        android:layout_marginBottom="12dp" />

                    <RadioGroup
                        android:id="@+id/rgCategory"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <!-- Security Option -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/gray_200"
                            app:strokeWidth="2dp"
                            app:cardBackgroundColor="@color/white">

                            <RadioButton
                                android:id="@+id/rbSecurity"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Security"
                                android:textSize="14sp"
                                android:textColor="@color/navy_blue"
                                android:padding="16dp"
                                android:drawableStart="@drawable/ic_shield"
                                android:drawablePadding="12dp"
                                android:drawableTint="@color/navy_blue"
                                android:buttonTint="@color/navy_blue" />

                        </androidx.cardview.widget.CardView>

                        <!-- Infrastructure Option -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/navy_blue"
                            app:strokeWidth="2dp"
                            app:cardBackgroundColor="@color/navy_blue_10">

                            <RadioButton
                                android:id="@+id/rbInfrastructure"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Infrastructure"
                                android:textSize="14sp"
                                android:textColor="@color/navy_blue"
                                android:padding="16dp"
                                android:drawableStart="@drawable/ic_build"
                                android:drawablePadding="12dp"
                                android:drawableTint="@color/navy_blue"
                                android:buttonTint="@color/navy_blue"
                                android:checked="true" />

                        </androidx.cardview.widget.CardView>

                        <!-- Environmental Option -->
                        <androidx.cardview.widget.CardView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:cardCornerRadius="8dp"
                            app:cardElevation="0dp"
                            app:strokeColor="@color/gray_200"
                            app:strokeWidth="2dp"
                            app:cardBackgroundColor="@color/white">

                            <RadioButton
                                android:id="@+id/rbEnvironmental"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="Environmental"
                                android:textSize="14sp"
                                android:textColor="@color/navy_blue"
                                android:padding="16dp"
                                android:drawableStart="@drawable/ic_eco"
                                android:drawablePadding="12dp"
                                android:drawableTint="@color/navy_blue"
                                android:buttonTint="@color/navy_blue" />

                        </androidx.cardview.widget.CardView>

                    </RadioGroup>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Alert Title -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alert Title"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/navy_blue"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="type here..."
                        app:boxStrokeColor="@color/navy_blue"
                        app:hintTextColor="@color/navy_blue" app:helperText=""
                        app:helperTextTextColor="@color/gray_600"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etAlertTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapSentences"
                            android:maxLines="2" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Location Section -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <!-- Location Title and GPS Button -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="8dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Location"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/navy_blue" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnUseGPS"
                            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Use GPS"
                            android:textColor="@color/navy_blue"
                            android:textAllCaps="false"
                            android:textSize="12sp"
                            app:icon="@drawable/ic_gps"
                            app:iconSize="18dp"
                            app:iconTint="@color/navy_blue"
                            app:iconGravity="textStart"
                            app:strokeColor="@color/navy_blue"
                            app:strokeWidth="2dp"
                            app:cornerRadius="8dp" />

                    </LinearLayout>

                    <!-- GPS Acquired Banner -->
                    <LinearLayout
                        android:id="@+id/gpsAcquiredBanner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp"
                        android:gravity="center_vertical"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <ImageView
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_location"
                            android:contentDescription="@string/location" />

                        <TextView
                            android:id="@+id/tvGpsCoordinates"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="location"
                            android:textSize="12sp"
                            android:textColor="@color/status_green_text"
                            android:layout_marginStart="8dp" />

                    </LinearLayout>

                    <!-- Building/Area Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Building"
                        app:boxStrokeColor="@color/navy_blue"
                        app:hintTextColor="@color/navy_blue"
                        android:layout_marginBottom="12dp"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etBuilding"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text" />

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Room/Section Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="room_section"
                        app:boxStrokeColor="@color/navy_blue"
                        app:hintTextColor="@color/navy_blue"
                        app:helperText="location_helper"
                        app:helperTextTextColor="@color/gray_600"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etRoomSection"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Priority Level -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Required Priority Level"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/navy_blue"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Select Priority"
                        app:boxStrokeColor="@color/navy_blue"
                        app:hintTextColor="@color/navy_blue"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">

                        <AutoCompleteTextView
                            android:id="@+id/actvPriority"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="none"
                            android:textColor="@color/gray_900" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Description -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Description"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/navy_blue"
                        android:layout_marginBottom="8dp" />

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="type here..."
                        app:boxStrokeColor="@color/navy_blue"
                        app:hintTextColor="@color/navy_blue"
                        app:helperText="description_helper"
                        app:helperTextTextColor="@color/gray_600"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDescription"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textMultiLine|textCapSentences"
                            android:lines="5"
                            android:gravity="top|start"
                            android:minLines="5" />

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Photo/Video Upload -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Attach Photo"
                        android:textStyle="bold"
                        android:textSize="14sp"
                        android:textColor="@color/navy_blue"
                        android:layout_marginBottom="12dp" />

                    <!-- Upload Area -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="24dp"
                        android:gravity="center">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_stat_icon_primary">

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:layout_gravity="center"
                                android:src="@drawable/ic_upload"
                                android:background="@drawable/bg_upload_area"
                                android:contentDescription="upload" />

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Upload Photo"
                            android:textStyle="bold"
                            android:textSize="14sp"
                            android:textColor="@color/navy_blue"
                            android:layout_marginTop="12dp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=""
                            android:textSize="12sp"
                            android:textColor="@color/gray_600"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <com.google.android.material.button.MaterialButton
                                android:id="@+id/btnTakePhoto"
                                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Photo"
                                android:textColor="@color/navy_blue"
                                android:textAllCaps="false"
                                android:textSize="12sp"
                                app:icon="@drawable/ic_camera"
                                app:iconSize="18dp"
                                app:iconTint="@color/navy_blue"
                                app:strokeColor="@color/gray_300"
                                app:strokeWidth="2dp"
                                app:cornerRadius="8dp"
                                android:layout_marginEnd="8dp" />
                        </LinearLayout>

                    </LinearLayout>

                    <!-- Uploaded Files Preview (initially hidden) -->
                    <LinearLayout
                        android:id="@+id/uploadedFilesContainer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="12dp"
                        android:visibility="gone"
                        tools:visibility="visible">

                        <!-- Sample uploaded file item -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:padding="12dp"
                            android:gravity="center_vertical">

                            <View
                                android:layout_width="48dp"
                                android:layout_height="48dp"
                                android:background="@color/stat_primary_bg" />

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:layout_marginStart="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="IMG_2024_001.jpg"
                                    android:textStyle="bold"
                                    android:textSize="14sp"
                                    android:textColor="@color/navy_blue"
                                    android:ellipsize="end"
                                    android:maxLines="1" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="2.4 MB"
                                    android:textSize="12sp"
                                    android:textColor="@color/gray_600" />

                            </LinearLayout>

                            <ImageButton
                                android:layout_width="40dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_close"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="remove" />

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- Contact Preferences -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:cardBackgroundColor="@color/white">


            </androidx.cardview.widget.CardView>

            <!-- Submit Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnCancel"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Cancel"
                    android:textColor="@color/gray_700"
                    android:textAllCaps="false"
                    app:strokeColor="@color/gray_300"
                    app:strokeWidth="2dp"
                    app:cornerRadius="8dp"
                    android:layout_marginEnd="8dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnSubmitReport"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Submit"
                    android:textColor="@color/white"
                    android:textAllCaps="false"
                    android:backgroundTint="@color/alert_red"
                    app:cornerRadius="8dp" />

            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>