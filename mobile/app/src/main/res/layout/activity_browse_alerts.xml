<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:orientation="horizontal"
        android:padding="10dp"
        android:gravity="center_vertical"
        android:background="@color/navy_blue">

        <FrameLayout
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@drawable/logo_background">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:src="@drawable/ic_alert_triangle"
                android:contentDescription="@string/app_name" />
        </FrameLayout>

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Browse Alerts"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:layout_marginStart="12dp" />
    </LinearLayout>

    <!-- Filters and list content -->

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="8dp"
        app:cardElevation="4dp"
        android:layout_margin="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Filters"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/navy_blue"
                android:layout_marginBottom="12dp" />

            <!-- Search Input -->
            <EditText
                android:id="@+id/searchInput"
                android:layout_width="match_parent"
                android:layout_height="38dp"
                android:hint="Search alerts..."
                android:background="@drawable/rounded_edittext"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:textSize="14sp"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:layout_marginBottom="8dp"
                android:importantForAutofill="no" />

            <Button
                android:id="@+id/searchButton"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:text="Search"
                android:textSize="12dp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_marginBottom="12dp" />

            <!-- Status Filter -->
            <Spinner
                android:id="@+id/statusFilter"
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:background="@drawable/rounded_spinner"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="12dp"
                android:contentDescription="Status Filter" />

            <!-- Category Filter -->
            <Spinner
                android:id="@+id/categoryFilter"
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:background="@drawable/rounded_spinner"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="12dp"
                android:contentDescription="Category Filter" />

            <!-- Priority Filter -->
            <Spinner
                android:id="@+id/priorityFilter"
                android:layout_width="match_parent"
                android:layout_height="26dp"
                android:background="@drawable/rounded_spinner"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginBottom="12dp"
                android:contentDescription="Priority Filter" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Quick Filters and Category Buttons -->
    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:layout_marginBottom="8dp"
        android:fillViewport="true"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/filterAll"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="All"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/filterHighPriority"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="High Priority"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/filterNew"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="New"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/filterResolved"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Resolved"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/filterSecurity"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Security"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/filterInfrastructure"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Infrastructure"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/filterEnvironmental"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="Environmental"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton" />
        </LinearLayout>
    </HorizontalScrollView>

    <!-- Alerts List -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/alertsCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Showing 0 alerts"
            android:textSize="14sp"
            android:textColor="@color/gray_600"
            android:layout_marginBottom="12dp" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvBrowseAlerts"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:overScrollMode="always" />
    </LinearLayout>

</LinearLayout>